{
  "version": 3,
  "configurePresets": [
    {
      "name": "default",
      "description": "Build without tests",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "BUILD_TESTS": "OFF"
      }
    },
    {
      "name": "with-tests",
      "description": "Build with tests (for development/IntelliSense)",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "BUILD_TESTS": "ON"
      }
    }
  ]
}
